{
  "expo": {
    "name": "IceIQ",
    "slug": "iceiq-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "iceiq",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0A0A0F"
    },
    "ios": { "supportsTablet": true },
    "android": { "adaptiveIcon": { "backgroundColor": "#0A0A0F" } },
    "web": { "bundler": "metro" },
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
